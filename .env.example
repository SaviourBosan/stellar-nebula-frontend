# ============================================================
# Stellar Nebula Frontend — Environment Variables
# Copy this file to .env.local for development.
# ============================================================

# App
VITE_APP_ENV=development          # development | staging | production
VITE_APP_NAME=Stellar Nebula
VITE_APP_VERSION=0.0.0

# ── Stellar Network ─────────────────────────────────────────
# Network to connect to: testnet | mainnet | futurenet
VITE_STELLAR_NETWORK=testnet

# Soroban RPC endpoint
VITE_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Horizon REST API
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Network passphrase (required for transaction signing)
VITE_STELLAR_PASSPHRASE=Test SDF Network ; September 2015

# ── Contract IDs ─────────────────────────────────────────────
# Deployed Soroban contract addresses (C… format)
VITE_NEBULA_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4
VITE_TOKEN_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAABSC4

# ── API ──────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT_MS=10000

# ── Feature Flags ────────────────────────────────────────────
VITE_ENABLE_DEV_TOOLS=true
VITE_ENABLE_FPS_COUNTER=true
