VITE_APP_ENV=staging
VITE_APP_NAME=Stellar Nebula
VITE_APP_VERSION=0.0.0

VITE_STELLAR_NETWORK=testnet
VITE_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_STELLAR_PASSPHRASE=Test SDF Network ; September 2015

# Set these in your CI/CD secrets — do not commit real values
VITE_NEBULA_CONTRACT_ID=
VITE_TOKEN_CONTRACT_ID=

VITE_API_BASE_URL=https://staging-api.stellarnebula.io/api
VITE_API_TIMEOUT_MS=12000

VITE_SENTRY_DSN=https://examplePublicKey@oXXXXX.ingest.us.sentry.io/XXXXX

VITE_ENABLE_DEV_TOOLS=true
VITE_ENABLE_FPS_COUNTER=false
